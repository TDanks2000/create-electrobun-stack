{
  "name": "create-electrobun-stack",
  "version": "0.1.1",
  "description": "Scaffold a modern Electrobun desktop app.",
  "type": "module",
  "bin": {
    "create-electrobun-stack": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "files": [
    "docs",
    "src",
    "templates"
  ],
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "^1.3.8",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
