{{#if hasElectrobunRpc}}
import type { RPCSchema } from "electrobun";
import type * as Shared from "../types";

export type MainViewRPC = {
  bun: RPCSchema<{
    messages: {
      {{#if hasRpcExample}}
      logToBun: {
        message: string;
      };
      {{/if}}
    };
    requests: {
      getEnvironment: {
        params: null;
        response: Shared.AppEnvironment;
      };
      {{#if hasNativeFileDialogs}}
      openFileDialog: {
        params: null;
        response: Shared.FileDialogResult;
      };
      {{/if}}
      {{#if hasRpcExample}}
      greet: {
        params: {
          name: string;
        };
        response: {
          greeting: string;
        };
      };
      {{/if}}
      {{#if hasDatabase}}
      getDatabaseStatus: {
        params: null;
        response: Shared.DatabaseStatus;
      };
      {{/if}}
      {{#if hasSettings}}
      getSettingsStatus: {
        params: null;
        response: Shared.SettingsStatus;
      };
      updateSetting: {
        params: {
          key: string;
          value: Shared.SettingValue;
        };
        response: Shared.SettingsStatus;
      };
      {{/if}}
    };
  }>;
  webview: RPCSchema<{
    messages: {
      logToWebview: {
        message: string;
      };
    };
    requests: {
      getViewStatus: {
        params: null;
        response: {
          ready: boolean;
        };
      };
    };
  }>;
};
{{else}}
export type MainViewRPC = never;
{{/if}}
