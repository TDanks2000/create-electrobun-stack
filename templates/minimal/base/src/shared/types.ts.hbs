export type AppEnvironment = {
  appName: string;
  platform: NodeJS.Platform;
  startedAt: string;
};
{{#if hasNativeFileDialogs}}

export type FileDialogResult = {
  paths: Array<string>;
};
{{/if}}
{{#if hasNativeClipboard}}

export type ClipboardStatus = {
  formats: Array<string>;
  text: string | null;
  updatedAt: string;
};
{{/if}}
{{#if hasDatabase}}

export type DatabaseStatus = {
  driver: "bun:sqlite" | "drizzle" | "json-file";
  path: string;
  records: number;
};
{{/if}}
{{#if hasSettings}}

export type SettingValue = string | number | boolean | null;

export type AppSettings = Record<string, SettingValue>;

export type SettingsStatus = {
  path: string;
  storage: "json" | "database";
  updatedAt: string;
  values: AppSettings;
};
{{/if}}
