import { createRoute } from "@tanstack/react-router";
{{#if hasElectrobunRpc}}
import { useEffect, useState } from "react";
{{else}}
{{#if hasAppLock}}
import { useState } from "react";
{{/if}}
{{/if}}
import { APP_NAME } from "../../../shared/constants";
{{#if hasElectrobunRpc}}
import type {
  AppEnvironment,
{{#if hasDatabase}}
  DatabaseStatus,
{{/if}}
{{#if hasSettings}}
  SettingValue,
  SettingsStatus,
{{/if}}
} from "../../../shared/types";
import { rpc } from "../lib/rpc";
{{/if}}
import { rootRoute } from "./__root";

const Home = () => {
{{#if hasElectrobunRpc}}
  const [environment, setEnvironment] = useState<AppEnvironment | null>(null);
{{/if}}
{{#if hasAppLock}}
  const [unlockInput, setUnlockInput] = useState("");
  const [isUnlocked, setIsUnlocked] = useState(false);
{{/if}}
{{#if hasRpcExample}}
  const [greeting, setGreeting] = useState("Waiting for Bun...");
{{/if}}
{{#if hasElectrobunRpc}}
{{#if hasDatabase}}
  const [database, setDatabase] = useState<DatabaseStatus | null>(null);
{{/if}}
{{#if hasSettings}}
  const [settings, setSettings] = useState<SettingsStatus | null>(null);
  const [isSavingSetting, setIsSavingSetting] = useState(false);
{{/if}}
{{/if}}
{{#if hasElectrobunRpc}}
  const isReady = environment !== null;
{{else}}
  const isReady = true;
{{/if}}
{{#if hasElectrobunRpc}}

  useEffect(() => {
    let mounted = true;

    const load = async () => {
      const environmentRequest = rpc.request.getEnvironment(null);
{{#if hasRpcExample}}
      const greetingRequest = rpc.request.greet({ name: APP_NAME });
{{/if}}
{{#if hasDatabase}}
      const databaseRequest = rpc.request.getDatabaseStatus(null);
{{/if}}
{{#if hasSettings}}
      const settingsRequest = rpc.request.getSettingsStatus(null);
{{/if}}

      const environmentResult = await environmentRequest;
{{#if hasRpcExample}}
      const greetingResult = await greetingRequest;
{{/if}}
{{#if hasDatabase}}
      const databaseResult = await databaseRequest;
{{/if}}
{{#if hasSettings}}
      const settingsResult = await settingsRequest;
{{/if}}

      if (!mounted) {
        return;
      }

      setEnvironment(environmentResult);
{{#if hasRpcExample}}
      setGreeting(greetingResult.greeting);
{{/if}}
{{#if hasDatabase}}
      setDatabase(databaseResult);
{{/if}}
{{#if hasSettings}}
      setSettings(settingsResult);
{{/if}}
{{#if hasRpcExample}}
      rpc.send.logToBun({ message: "Renderer loaded and called Bun RPC." });
{{/if}}
    };

    void load();

    return () => {
      mounted = false;
    };
  }, []);
{{#if hasSettings}}

  const saveSetting = async (key: string, value: SettingValue) => {
    setIsSavingSetting(true);

    try {
      setSettings(await rpc.request.updateSetting({ key, value }));
    } finally {
      setIsSavingSetting(false);
    }
  };
{{/if}}
{{/if}}
{{#if hasAppLock}}

  if (!isUnlocked) {
    return (
      <main className="shell">
        <div className="ambient-grid" aria-hidden="true" />
        <section className="panel auth-panel">
          <p className="eyebrow">Local app lock</p>
          <h1>{APP_NAME}</h1>
          <p className="lede">
            Enter the app name to unlock this local desktop session.
          </p>
          <form
            className="auth-form"
            onSubmit={(event) => {
              event.preventDefault();
              setIsUnlocked(
                unlockInput.trim().toLowerCase() === APP_NAME.toLowerCase(),
              );
            }}
          >
            <input
              aria-label="Unlock phrase"
              onChange={(event) => setUnlockInput(event.target.value)}
              placeholder={APP_NAME}
              type="password"
              value={unlockInput}
            />
            <button type="submit">Unlock</button>
          </form>
        </section>
      </main>
    );
  }
{{/if}}

  return (
    <main className="shell">
{{#if hasHiddenInsetTitlebar}}
      <div
        aria-hidden="true"
        className="window-drag-bar electrobun-webkit-app-region-drag"
      >
        <span>{APP_NAME}</span>
      </div>
{{/if}}
      <div className="ambient-grid" aria-hidden="true" />
      <section className="panel">
        <div className="masthead">
          <p className="eyebrow">Electrobun + React</p>
          <span className={`runtime-pill ${isReady ? "is-ready" : ""}`}>
            <span className="pulse" />
{{#if hasElectrobunRpc}}
            {isReady ? "Bun RPC online" : "Connecting"}
{{else}}
            {isReady ? "Renderer ready" : "Connecting"}
{{/if}}
          </span>
        </div>
        <h1>{APP_NAME}</h1>
{{#if hasRpcExample}}
        <p className="lede">{greeting}</p>
{{else}}
{{#if hasElectrobunRpc}}
        <p className="lede">
          A focused Electrobun desktop app scaffold with typed runtime status
          wired from Bun to React.
        </p>
{{else}}
        <p className="lede">
          A focused Electrobun desktop app scaffold with a local React
          interface.
        </p>
{{/if}}
{{/if}}
        <div className="grid">
          <div>
            <span>Router</span>
            <strong>TanStack Router</strong>
          </div>
          <div>
            <span>Styles</span>
            <strong>{{#if hasTailwind}}Tailwind CSS{{else}}Plain CSS{{/if}}</strong>
          </div>
          <div>
            <span>RPC</span>
{{#if hasElectrobunRpc}}
            <strong>Typed Electrobun RPC</strong>
{{else}}
            <strong>Not configured</strong>
{{/if}}
          </div>
          {{#if hasElectrobunRpc}}
          {{#if hasDatabase}}
          <div>
            <span>Database</span>
            <strong>
              {database
                ? `${database.driver} / ${database.records} rows`
                : "Loading"}
            </strong>
          </div>
          {{/if}}
          {{#if hasSettings}}
          <div>
            <span>Settings</span>
            <strong>
              {settings
                ? `${settings.storage} / ${Object.keys(settings.values).length} keys`
                : "Loading"}
            </strong>
          </div>
          {{/if}}
          {{/if}}
        </div>
{{#if hasSettings}}
        <div className="settings-controls">
          <span>app.theme</span>
          <div aria-label="Theme setting" className="segmented" role="group">
            {(["system", "light", "dark"] as const).map((theme) => (
              <button
                className={
                  settings?.values["app.theme"] === theme ? "is-active" : ""
                }
                disabled={isSavingSetting}
                key={theme}
                onClick={() => void saveSetting("app.theme", theme)}
                type="button"
              >
                {theme}
              </button>
            ))}
          </div>
        </div>
{{/if}}
        <dl className="facts">
          <div>
            <dt>Platform</dt>
{{#if hasElectrobunRpc}}
            <dd>{environment?.platform ?? "Loading"}</dd>
{{else}}
            <dd>{navigator.platform || "BrowserView"}</dd>
{{/if}}
          </div>
          <div>
            <dt>Started</dt>
{{#if hasElectrobunRpc}}
            <dd>{environment?.startedAt ?? "Loading"}</dd>
{{else}}
            <dd>Renderer ready</dd>
{{/if}}
          </div>
          {{#if hasElectrobunRpc}}
          {{#if hasDatabase}}
          <div>
            <dt>Database file</dt>
            <dd>{database?.path ?? "Loading"}</dd>
          </div>
          {{/if}}
          {{#if hasSettings}}
          <div>
            <dt>Settings store</dt>
            <dd>{settings?.path ?? "Loading"}</dd>
          </div>
          {{/if}}
          {{/if}}
        </dl>
      </section>
    </main>
  );
};

export const indexRoute = createRoute({
  component: Home,
  getParentRoute: () => rootRoute,
  path: "/",
});
