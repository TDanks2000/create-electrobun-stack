{{#if hasElectrobunRpc}}
import { BrowserView } from "electrobun/bun";
import type { MainViewRPC } from "../../shared/rpc/types";
import * as handlers from "./handlers";

export const mainViewRPC = BrowserView.defineRPC<MainViewRPC>({
  handlers: {
    messages: {
{{#if hasRpcExample}}
      logToBun: handlers.logToBun,
{{/if}}
    },
    requests: {
{{#if hasDatabase}}
      getDatabaseStatus: handlers.getDatabaseStatus,
{{/if}}
      getEnvironment: handlers.getEnvironment,
{{#if hasSettings}}
      getSettingsStatus: handlers.getSettingsStatus,
{{/if}}
{{#if hasRpcExample}}
      greet: handlers.greet,
{{/if}}
{{#if hasNativeFileDialogs}}
      openFileDialog: handlers.openFileDialog,
{{/if}}
{{#if hasSettings}}
      updateSetting: handlers.updateSetting,
{{/if}}
    },
  },
  maxRequestTime: 5000,
});
{{else}}
export const mainViewRPC = null;
{{/if}}
