{{#if hasElectrobunRpc}}
import { BrowserView } from "electrobun/bun";
import type { MainViewRPC } from "../../shared/rpc/types";
import {
{{#if hasDatabase}}
  getDatabaseStatus,
{{/if}}
{{#if hasRpcExample}}
  greet,
  logToBun,
{{/if}}
  getEnvironment,
{{#if hasSettings}}
  getSettingsStatus,
  updateSetting,
{{/if}}
} from "./handlers";

export const mainViewRPC = BrowserView.defineRPC<MainViewRPC>({
  handlers: {
    messages: {
{{#if hasRpcExample}}
      logToBun,
{{/if}}
    },
    requests: {
{{#if hasDatabase}}
      getDatabaseStatus,
{{/if}}
      getEnvironment,
{{#if hasSettings}}
      getSettingsStatus,
{{/if}}
{{#if hasRpcExample}}
      greet,
{{/if}}
{{#if hasSettings}}
      updateSetting,
{{/if}}
    },
  },
  maxRequestTime: 5000,
});
{{else}}
export const mainViewRPC = null;
{{/if}}
