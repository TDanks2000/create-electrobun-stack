{{#if hasNativeFileDialogs}}import { Utils } from "electrobun/bun";
{{else}}
{{#if hasNativeClipboard}}import { Utils } from "electrobun/bun";
{{/if}}
{{/if}}
import { APP_NAME } from "../../shared/constants";
{{#if hasNativeFileDialogs}}
import type {
  AppEnvironment,
{{#if hasNativeClipboard}}
  ClipboardStatus,
{{/if}}
  FileDialogResult,
} from "../../shared/types";
{{else}}
{{#if hasNativeClipboard}}
import type {
  AppEnvironment,
  ClipboardStatus,
} from "../../shared/types";
{{else}}
import type { AppEnvironment } from "../../shared/types";
{{/if}}
{{/if}}
{{#if hasDatabase}}import { getDatabaseStatus } from "../db/client";
{{/if}}
{{#if hasSettings}}import { getSettingsStatus, updateSetting } from "../settings/store";
{{/if}}

const startedAt = new Date().toISOString();

export const getEnvironment = (): AppEnvironment => ({
  appName: APP_NAME,
  platform: process.platform,
  startedAt,
});
{{#if hasNativeFileDialogs}}

export const openFileDialog = async (): Promise<FileDialogResult> => {
  const paths =
    (await Utils.openFileDialog({
      allowedFileTypes: "*",
      allowsMultipleSelection: false,
      canChooseDirectory: true,
      canChooseFiles: true,
      startingFolder: Utils.paths.home,
    })) ?? [];

  return { paths };
};
{{/if}}
{{#if hasNativeClipboard}}

const getClipboardStatus = (): ClipboardStatus => ({
  formats: Utils.clipboardAvailableFormats(),
  text: Utils.clipboardReadText(),
  updatedAt: new Date().toISOString(),
});

export const clearClipboard = (): ClipboardStatus => {
  Utils.clipboardClear();
  return getClipboardStatus();
};

export const readClipboard = (): ClipboardStatus => getClipboardStatus();

export const writeClipboard = ({ text }: { text: string }): ClipboardStatus => {
  Utils.clipboardWriteText(text);
  return getClipboardStatus();
};
{{/if}}
{{#if hasRpcExample}}

export const greet = ({ name }: { name: string }): { greeting: string } => ({
  greeting: `Hello, ${name || "Electrobun"} from Bun.`,
});

export const logToBun = ({ message }: { message: string }): void => {
  console.log(`[webview] ${message}`);
};
{{/if}}
{{#if hasDatabase}}
{{#if hasSettings}}
export { getDatabaseStatus, getSettingsStatus, updateSetting };
{{else}}
export { getDatabaseStatus };
{{/if}}
{{else}}
{{#if hasSettings}}
export { getSettingsStatus, updateSetting };
{{/if}}
{{/if}}
