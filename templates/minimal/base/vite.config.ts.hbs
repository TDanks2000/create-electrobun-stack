{{#unless hasSvelteKitFrontend}}
import { fileURLToPath, URL } from "node:url";
{{/unless}}
{{#if hasPreactFrontend}}
import preact from "@preact/preset-vite";
{{/if}}
{{#if hasSvelteKitFrontend}}
import { sveltekit } from "@sveltejs/kit/vite";
{{/if}}
{{#if hasSvelteFrontend}}
import { svelte } from "@sveltejs/vite-plugin-svelte";
{{/if}}
{{#if hasTailwind}}
import tailwindcss from "@tailwindcss/vite";
{{/if}}
{{#if hasTanstackRouter}}
import { tanstackRouter } from "@tanstack/router-plugin/vite";
{{/if}}
{{#if hasReactFrontend}}
import react from "@vitejs/plugin-react";
{{/if}}
import { defineConfig } from "vite";
{{#unless hasSvelteKitFrontend}}

const rendererPlugin = {{#if hasPreactFrontend}}preact(){{else}}{{#if hasSvelteFrontend}}svelte({ configFile: false }){{else}}react(){{/if}}{{/if}};
{{/unless}}

export default defineConfig({
{{#if hasSvelteKitFrontend}}
{{#if hasTailwind}}
  plugins: [tailwindcss(), sveltekit()],
{{else}}
  plugins: [sveltekit()],
{{/if}}
{{else}}
  base: "./",
  build: {
    emptyOutDir: true,
    outDir: "../../../.electrobun/views/main",
  },
{{#if hasTanstackRouter}}
  plugins: [
    tanstackRouter({
      autoCodeSplitting: true,
      generatedRouteTree: "./routeTree.gen.ts",
      quoteStyle: "double",
      routesDirectory: "./routes",
      semicolons: true,
      target: "react",
    }),
{{#if hasTailwind}}
    tailwindcss(),
{{/if}}
    rendererPlugin,
  ],
{{else}}
{{#if hasTailwind}}
  plugins: [tailwindcss(), rendererPlugin],
{{else}}
  plugins: [rendererPlugin],
{{/if}}
{{/if}}
  resolve: {
    alias: {
      "@": fileURLToPath(new URL("./src", import.meta.url)),
    },
  },
  root: "src/views/main",
{{/if}}
});
