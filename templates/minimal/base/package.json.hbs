{
  "name": "__PACKAGE_NAME__",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite build && concurrently -k -n vite,electrobun \"vite build --watch\" \"electrobun dev\"",
    "build": "vite build && electrobun build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write ."{{#if hasDrizzle}},
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"{{/if}}
  },
  "dependencies": {
    "@tanstack/react-router": "^1.166.6",
{{#if hasDrizzle}}
    "drizzle-orm": "^0.45.2",
{{/if}}
    "electrobun": "^1.16.0",
    "react": "^19.2.0",
{{#if hasTailwind}}
    "react-dom": "^19.2.0",
{{#if hasShadcn}}
    "shadcn": "^3.6.2",
    "tw-animate-css": "^1.3.4",
{{/if}}
    "tailwindcss": "^4.1.10"
{{else}}
    "react-dom": "^19.2.0"
{{/if}}
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/bun": "^1.3.8",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
{{#if hasTailwind}}
    "@tailwindcss/vite": "^4.1.10",
{{/if}}
{{#if hasDrizzle}}
    "drizzle-kit": "^0.31.9",
{{/if}}
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
