{
{{#if hasSvelteKitFrontend}}
  "extends": "./.svelte-kit/tsconfig.json",
{{/if}}
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
{{#if hasPreactFrontend}}
    "jsxImportSource": "preact",
{{/if}}
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
{{#unless hasSvelteKitFrontend}}
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
{{/unless}}
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "types": ["bun"]
{{#if hasSvelteKitFrontend}}
  }
{{else}}
  },
{{#if hasInstallerPackaging}}
  "include": [
    "src",
    "electrobun.config.ts",
    "vite.config.ts"{{#if hasTesting}},
    "tests"{{/if}}{{#if hasInstallerPackaging}},
    "scripts"{{/if}}
  ]
{{else}}
  "include": ["src", "electrobun.config.ts", "vite.config.ts"{{#if hasTesting}}, "tests"{{/if}}]
{{/if}}
{{/if}}
}
