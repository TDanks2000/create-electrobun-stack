import { databasePath, sqlite } from "../db/client";
import type {
  AppSettings,
  SettingsStatus,
  SettingValue,
} from "../../shared/types";

const defaultSettings: AppSettings = {
  "app.theme": "system",
  "editor.formatOnSave": true,
  "window.restorePreviousSession": true,
};

type SettingsRow = {
  key: string;
  updated_at: string;
  value: string;
};

sqlite.exec(`
  create table if not exists app_settings (
    key text primary key,
    value text not null,
    updated_at text not null
  );
`);

const isSettingValue = (value: unknown): value is SettingValue =>
  value === null ||
  typeof value === "string" ||
  typeof value === "number" ||
  typeof value === "boolean";

const parseSettingValue = (value: string): SettingValue => {
  try {
    const parsed: unknown = JSON.parse(value);
    return isSettingValue(parsed) ? parsed : null;
  } catch {
    return null;
  }
};

const insertDefaultSetting = sqlite.query(`
  insert into app_settings (key, value, updated_at)
  values ($key, $value, $updatedAt)
  on conflict(key) do nothing
`);

const writeSetting = sqlite.query(`
  insert into app_settings (key, value, updated_at)
  values ($key, $value, $updatedAt)
  on conflict(key) do update set
    value = excluded.value,
    updated_at = excluded.updated_at
`);

const ensureDefaultSettings = (): void => {
  const updatedAt = new Date().toISOString();

  for (const [key, value] of Object.entries(defaultSettings)) {
    insertDefaultSetting.run({
      key,
      updatedAt,
      value: JSON.stringify(value),
    });
  }
};

const readSettings = (): { updatedAt: string; values: AppSettings } => {
  ensureDefaultSettings();

  const rows = sqlite
    .query("select key, value, updated_at from app_settings order by key")
    .all() as Array<SettingsRow>;
  const values: AppSettings = {};
  let updatedAt = rows.at(0)?.updated_at ?? new Date().toISOString();

  for (const row of rows) {
    values[row.key] = parseSettingValue(row.value);

    if (row.updated_at > updatedAt) {
      updatedAt = row.updated_at;
    }
  }

  return { updatedAt, values };
};

export const getSettingsStatus = (): SettingsStatus => {
  const { updatedAt, values } = readSettings();

  return {
    path: databasePath,
    storage: "database",
    updatedAt,
    values,
  };
};

export const updateSetting = ({
  key,
  value,
}: {
  key: string;
  value: SettingValue;
}): SettingsStatus => {
  const normalizedKey = key.trim();

  if (!normalizedKey) {
    throw new Error("Setting key is required.");
  }

  writeSetting.run({
    key: normalizedKey,
    updatedAt: new Date().toISOString(),
    value: JSON.stringify(value),
  });

  return getSettingsStatus();
};
