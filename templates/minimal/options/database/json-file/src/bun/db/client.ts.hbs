      {
        createdAt: new Date().toISOString(),
        id: crypto.randomUUID(),
        key: "starter",
        value: "JSON file database is ready.",
      },
    ],
  });
}
{{/if}}

export const getDatabaseStatus = (): DatabaseStatus => {
  const database = readDatabase();

  return {
    driver: "json-file",
    path: databasePath,
    records: database.records.length,
  };
};
